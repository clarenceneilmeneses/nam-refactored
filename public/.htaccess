# SPA fallback (Apache/LiteSpeed, e.g. Hostinger): any path that isn't a real
# file or folder serves index.html so React Router can handle the route.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
